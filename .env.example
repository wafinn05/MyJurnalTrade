# ===== TELEGRAM BOT =====
# Dapatkan token dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID Telegram Anda (akan terdeteksi otomatis saat pertama kali kirim pesan ke bot)
TELEGRAM_CHAT_ID=your_chat_id_here

# ===== DATABASE =====
# Gunakan PostgreSQL URL dari Supabase / Vercel Postgres / Neon
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/trading_dashboard

# ===== CRON JOB SECRET =====
# Secret untuk melindungi endpoint cron dari akses tidak sah
CRON_SECRET=your_random_secret_here

# ===== APP URL =====
# URL aplikasi saat di-deploy (untuk webhook Telegram)
NEXT_PUBLIC_APP_URL=http://localhost:3000
